{
  "expo": {
    "name": "Sınav Kilit",
    "slug": "ykstakip-mobile",
    "scheme": "ykstakip",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon-small.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.sinavkilit.app",
      "versionCode": 3,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.FOREGROUND_SERVICE"
      ]
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Çözemediğin soru görsellerini eklemek için galeriye erişim gerekir.",
          "cameraPermission": "Soru fotoğrafı çekmek için kamera izni gerekir."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "222fc8d9-d5ea-48da-a3a1-7d494017b2b8"
      }
    },
    "owner": "yusufsedat"
  }
}
