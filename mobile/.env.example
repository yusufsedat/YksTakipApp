# mobile/.env olarak kopyala (git'e ekleme). Expo'yu yeniden başlat.
#
# Fiziksel telefon / gerçek cihaz: bilgisayarın yerel IP'si (örn. 192.168.1.10).
# Backend http://0.0.0.0:5278 dinliyor olmalı (launchSettings http profili).
#
# EXPO_PUBLIC_API_URL=http://192.168.1.10:5278
#
# Android emülatör: aşağıdaki satırı kullan veya boş bırak (varsayılan 10.0.2.2).
# EXPO_PUBLIC_API_URL=http://10.0.2.2:5278
#
# iOS simülatör / web: localhost
# EXPO_PUBLIC_API_URL=http://localhost:5278
